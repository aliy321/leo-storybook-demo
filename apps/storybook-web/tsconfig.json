{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "noImplicitAny": false,
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@/components/*": ["../../packages/ui/src/*"],
      "@/ui/*": ["../../packages/ui/src/*"],
      "@/lib/*": ["../../packages/ui/src/lib/*"],
      "@/tokens/*": ["../../packages/tokens/*"],
      "@/tooling/*": ["../../tooling/*"],
      "@/apps/*": ["../../apps/*"],
      "@leo/ui": ["packages/ui/src/index.ts"],
      "@leo/ui/button": ["packages/ui/src/button/index.ts"],
      "@leo/tokens/css": ["packages/tokens/dist/global.css"],
      "@storybook/web-components": [
        "apps/storybook-web/node_modules/@storybook/web-components/dist/index.d.ts"
      ]
    }
  },
  "include": [
    "stories/**/*",
    ".storybook/**/*",
    "types/**/*.d.ts",
    "../../packages/ui/src/**/*.stories.ts",
    "../../packages/ui/src/**/*.mdx"
  ]
}
