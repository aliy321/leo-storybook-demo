{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "noImplicitAny": false,
    "lib": ["ES2022", "DOM"],
    "baseUrl": "../..",
    "paths": {
      "@leo/tokens/css": ["packages/tokens/dist/global.css"],
      "@storybook/web-components": [
        "apps/storybook-web/node_modules/@storybook/web-components/dist/index.d.ts"
      ]
    }
  },
  "include": [
    "stories/**/*",
    ".storybook/**/*",
    "types/**/*.d.ts",
    "../../packages/web/src/**/*.stories.ts",
    "../../packages/web/src/**/*.mdx"
  ]
}
