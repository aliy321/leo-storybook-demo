{
  "name": "@leo/button",
  "version": "3.0.0",
  "description": "LEO Button — unified web and React Native component",
  "type": "module",
  "license": "UNLICENSED",
  "main": "./Button.web.tsx",
  "types": "./index.ts",
  "exports": {
    ".": {
      "react-native": "./Button.native.tsx",
      "browser": "./Button.web.tsx",
      "default": "./Button.web.tsx",
      "types": "./index.ts"
    }
  },
  "files": [
    "Button.web.tsx",
    "Button.native.tsx",
    "Button.tsx",
    "index.ts"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "node scripts/assemble.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@leo/ui": "workspace:*",
    "@leo/tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@leo/native": "workspace:*",
    "@types/react": "^18.3.0",
    "nativewind": "^4.2.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "typescript": "~5.9.2"
  }
}
