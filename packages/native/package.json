{
  "name": "@leo/native",
  "version": "3.0.0",
  "private": true,
  "description": "All React Native components — single package, Metro transpiles source",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "react-native": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./button": {
      "types": "./src/button/Button.tsx",
      "react-native": "./src/button/Button.tsx",
      "default": "./src/button/Button.tsx"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@leo/tokens": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "nativewind": "^4.2.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "typescript": "~5.9.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "nativewind": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "nativewind": {
      "optional": true
    }
  }
}
