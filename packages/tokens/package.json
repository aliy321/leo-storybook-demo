{
  "name": "@leo/tokens",
  "version": "3.0.0",
  "description": "Shared design tokens for web and native",
  "type": "module",
  "exports": {
    "./css": "./dist/global.css",
    "./tailwind": "./dist/tailwind.preset.cjs",
    "./tailwind/native": "./rn/tailwind.preset.cjs",
    "./figma": "./dist/figma.variables.json",
    "./rn": {
      "types": "./rn/index.d.ts",
      "default": "./rn/index.js"
    },
    "./rn/tailwind.config.js": "./rn/tailwind.config.cjs",
    "./rn/tailwind.config.cjs": "./rn/tailwind.config.cjs",
    "./rn/data/colors": "./rn/data/colors.js",
    "./rn/data/themes": "./rn/data/themes.js",
    "./rn/data/themes.raw": "./rn/data/themes.raw.json",
    "./rn/data/typography": "./rn/data/typography.js"
  },
  "files": ["dist", "rn", "tokens"],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "node scripts/validate.cjs && node ../../scripts/clean-package-output.cjs packages/tokens/dist && node scripts/build.cjs && node scripts/build-css.cjs && node scripts/generate-figma.cjs",
    "dev": "node scripts/dev.mjs",
    "typecheck": "node scripts/validate.cjs",
    "token:pull": "node scripts/fetch.cjs",
    "token:build": "node scripts/validate.cjs && node ../../scripts/clean-package-output.cjs packages/tokens/dist && node scripts/build.cjs && node scripts/build-css.cjs && node scripts/generate-figma.cjs",
    "token:verify": "node scripts/validate.cjs",
    "token:push": "node scripts/push-figma.cjs",
    "token:push:dry": "node scripts/push-figma.cjs --dry-run"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  },
  "peerDependencies": {
    "nativewind": ">=4.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  }
}
