{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Configuration schema for Figma design token transformation",
  "description": "This configuration controls how Figma variables are transformed into design tokens. The fetch script now automatically preserves the ordering of tokens as defined by designers in Figma's variableIds array.",
  
  "defaults": {
    "fallbackValues": {
      "COLOR": "#000000",
      "FLOAT": 0,
      "STRING": ""
    },
    "excludeHiddenFromPublishing": true,
    "excludeDeletedButReferenced": true,
    "preservePlurals": true,
    "preserveFigmaOrdering": true,
    "multiMode": {
      "enabled": false,
      "outputStrategy": "single-file",
      "darkModeSuffix": "-dark"
    }
  },
  
  "transformations": {
    "cleanColorToken": {
      "type": "lastPart",
      "description": "Use last part of path for color tokens"
    },
    "joinAll": {
      "type": "join",
      "description": "Join all parts with kebab-case"
    },
    "lastPart": {
      "type": "lastPart",
      "description": "Use only the last part of the path"
    },
    "auto": {
      "type": "auto",
      "description": "Auto-detect based on path structure"
    }
  },
  
  "categoryOrder": ["colors", "typography", "spacing", "radius", "size", "border-width", "alpha", "layout", "shadow", "other"],
  "tokenMappings": {
    "COLOR": {
      "dtcgType": "color",
      "category": "colours",
      "patterns": [
        {
          "match": "colour",
          "category": "colours",
          "nameTransform": "cleanColorToken"
        },
        {
          "match": "color",
          "category": "colours",
          "nameTransform": "cleanColorToken"
        }
      ]
    },
    "FLOAT": {
      "dtcgType": "dimension",
      "patterns": [
        {
          "match": "font-weight",
          "category": "typography/font-weights",
          "nameTransform": "removePrefix:font-"
        },
        {
          "match": "line-height",
          "category": "typography/line-heights",
          "nameTransform": "removePrefix:line-height-"
        },
        {
          "match": "letter-spac",
          "category": "typography/letter-spacings",
          "nameTransform": "removePrefix:letter-space-"
        },
        {
          "match": "font-size",
          "category": "typography/font-sizes",
          "nameTransform": "removePrefix:font-size-"
        },
        {
          "match": "spacing",
          "category": "spacing",
          "nameTransform": "lastPart"
        },
        {
          "match": "radius",
          "category": "border-radius",
          "nameTransform": "lastPart"
        },
        {
          "match": "border-width",
          "category": "border-width",
          "nameTransform": "lastPart"
        },
        {
          "match": "grids and layouts",
          "category": "layouts",
          "nameTransform": "lastPart"
        },
        {
          "match": "opacity",
          "category": "opacity",
          "nameTransform": "lastPart"
        },
        {
          "match": "shadows",
          "category": "shadows",
          "nameTransform": "lastPart"
        }
      ],
      "defaultCategory": "other",
      "defaultNameTransform": "joinAll"
    },
    "STRING": {
      "dtcgType": "string",
      "defaultCategory": "other",
      "defaultNameTransform": "joinAll"
    }
  },
  "sorting": {
    "enabled": true,
    "categories": {
      "colors": {
        "pattern": "^(light-|dark-)?([a-z]+)-(\\d+)$",
        "sortBy": ["colorFamily", "variant", "numericScale"]
      }
    }
  },
  "outputFormat": {
    "indent": 2,
    "sortKeys": true
  },
  "collections": {
    "include": [
      {
        "name": "primitives"
      },
      {
        "name": "modes",
        "multiMode": {
          "enabled": true,
          "outputStrategy": "single-file"
        },
        "resolveReferences": {
          "enabled": true,
          "sourceCollections": ["primitives"]
        }
      },
      {
        "name": "typography",
        "multiMode": {
          "enabled": true,
          "outputStrategy": "single-file"
        },
        "resolveReferences": {
          "enabled": true,
          "sourceCollections": ["primitives"]
        },
        "excludeHiddenFromPublishing": false,
        "excludeTokenCategories": ["font-component"]
      },
      {
        "name": "grids",
        "multiMode": {
          "enabled": true,
          "outputStrategy": "single-file"
        },
        "flatStructure": true,
        "excludeHiddenFromPublishing": false
      },
      {
        "name": "shadows",
        "multiMode": {
          "enabled": true,
          "outputStrategy": "single-file"
        },
        "resolveReferences": {
          "enabled": true,
          "sourceCollections": ["primitives"]
        },
        "flatStructure": true
      }
    ],
    "exclude": [],
    "excludeTokenCategories": ["---"]
  },
  "referenceResolution": {
    "pattern": "^\\{([a-z0-9-]+(?:\\.[a-z0-9-]+)*)\\}$",
    "categoryMapping": {
      "colors": "colours",
      "colours": "colours",
      "icon": "colours",
      "border": "colours",
      "background": "colours",
      "text": "colours",
      "brand": "colours",
      "typography": "typography",
      "shadows": "shadows",
      "shadow-blur": "shadows",
      "shadow-offset": "shadows",
      "shadow-spread": "shadows"
    },
    "prefixStripping": {
      "font-weights": [],
      "letter-spacings": [],
      "line-heights": [],
      "font-sizes": []
    }
  }
}
