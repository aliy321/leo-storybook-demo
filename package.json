{
  "name": "leo-design-system-next",
  "version": "0.0.1",
  "private": true,
  "description": "LEO design system with Stencil web components, React Native components, and code-first tokens",
  "scripts": {
    "build": "turbo build --filter=@leo/tokens --filter=@leo/web --filter=@leo/native --filter=@leo/storybook-web --filter=@leo/storybook-native",
    "build:docs": "pnpm --filter @leo/storybook-web build && pnpm --filter @leo/storybook-native build",
    "dev": "pnpm dev:both",
    "dev:web": "turbo dev --filter=@leo/tokens --filter=@leo/web --filter=@leo/storybook-web",
    "dev:rn": "turbo dev --filter=@leo/tokens --filter=@leo/native --filter=@leo/storybook-native",
    "dev:both": "turbo dev --filter=@leo/tokens --filter=@leo/web --filter=@leo/native --filter=@leo/storybook-web --filter=@leo/storybook-native",
    "storybook:web": "pnpm --filter @leo/storybook-web dev",
    "storybook:rn": "pnpm --filter @leo/storybook-native dev",
    "typecheck": "turbo typecheck --filter=@leo/tokens --filter=@leo/web --filter=@leo/native --filter=@leo/storybook-web --filter=@leo/storybook-native",
    "lint": "turbo lint --filter=@leo/tokens --filter=@leo/web --filter=@leo/native --filter=@leo/storybook-web --filter=@leo/storybook-native",
    "token:pull": "pnpm --filter @leo/tokens token:pull",
    "token:build": "pnpm --filter @leo/tokens token:build",
    "token:verify": "pnpm --filter @leo/tokens token:verify",
    "token:verify:generated": "node scripts/verify-generated-tokens.cjs",
    "token:push": "pnpm --filter @leo/tokens token:build && pnpm --filter @leo/tokens token:push",
    "token:push:dry": "pnpm --filter @leo/tokens token:build && pnpm --filter @leo/tokens token:push:dry",
    "verify:packages": "node scripts/verify-package-boundaries.cjs",
    "verify:showcases": "bash scripts/verify-showcases.sh"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "~5.9.2"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  }
}
