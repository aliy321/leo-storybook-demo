import type { Meta, StoryObj } from '@storybook/web-components';
import { fn } from 'storybook/test';
import { defineCustomElements } from '@leo/web/loader';
import {
  {{camelCase name}}Contract,
  {{camelCase name}}VariantValues,
  type {{pascalCase name}}Options,
  type {{pascalCase name}}Variant,
} from '@leo/ui/{{name}}';
import { {{constantCase name}}_GALLERY_STORY_PARAMETERS } from '../story-shared';

defineCustomElements();

interface {{pascalCase name}}Args extends {{pascalCase name}}Options {
  variant: {{pascalCase name}}Variant;
  disabled: boolean;
  on{{pascalCase name}}Click?: ReturnType<typeof fn>;
}

function create{{pascalCase name}}(args: Partial<{{pascalCase name}}Args>, content = '{{pascalCase name}} content') {
  const el = document.createElement('{{tag name}}');
  el.setAttribute('variant', args.variant ?? 'default');
  if (args.disabled) el.setAttribute('disabled', 'true');
  el.textContent = content;
  if (args.on{{pascalCase name}}Click) {
    el.addEventListener('{{eventName name}}', args.on{{pascalCase name}}Click as EventListener);
