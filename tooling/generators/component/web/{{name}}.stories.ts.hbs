export const Disabled: Story = {
  parameters: {{constantCase name}}_GALLERY_STORY_PARAMETERS,
  render: () => {
    const wrapper = createStoryRow();
    for (const variant of {{camelCase name}}VariantValues) {
      wrapper.appendChild(
        create{{pascalCase name}}({ variant, disabled: true }, `${variant} (disabled)`),
