      options: {{camelCase name}}Contract.props.variant.values,
      description: {{camelCase name}}Contract.props.variant.description,
    },
    disabled: {
      control: 'boolean',
      description: {{camelCase name}}Contract.props.disabled.description,
    },
    on{{pascalCase name}}Click: {
      action: '{{eventName name}}',
      description: 'Fired when the component is clicked.',
    },
  },
  args: {
    variant: {{camelCase name}}Contract.props.variant.default,
    disabled: {{camelCase name}}Contract.props.disabled.default,
    on{{pascalCase name}}Click: fn(),
  },
};

export default meta;
type Story = StoryObj<{{pascalCase name}}Args>;

export const Default: Story = {
